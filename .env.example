# Required
YUKI_ACCESS_KEY=replace-with-yuki-webservice-access-key

# Optional: be or nl
YUKI_COUNTRY=be

# Optional defaults
YUKI_DEFAULT_DOMAIN_ID=
YUKI_DEFAULT_ADMINISTRATION_ID=

# Timeouts and budgets
YUKI_REQUEST_TIMEOUT_MS=15000
YUKI_MAX_CALLS_PER_MINUTE=120
YUKI_MAX_CALLS_PER_DAY=900

# Safety
YUKI_WRITE_OPERATIONS_ENABLED=false
YUKI_DEFAULT_DRY_RUN=true

# Logging
YUKI_LOG_LEVEL=info
YUKI_INCLUDE_RAW_RESPONSES=false
YUKI_ALLOW_SENSITIVE_DEBUG_LOGGING=false
